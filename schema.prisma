// LUMINA OVERMIND SYSTEM - PRISMA SCHEMA
// Enterprise-grade Intelligence & Automation Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Project Management - Core entity for multi-tenant isolation
model Project {
  id              String   @id @default(cuid())
  namaProyek      String   @db.VarChar(255)
  tipeProyek      String   @db.VarChar(50) // KOMERSIL or SUBSIDI
  lokasi          String   @db.VarChar(255)
  hargaStart      Float    @db.DoublePrecision
  targetMarket    String   @db.VarChar(255)
  tipeInputLokasi String   @default("NAMA_WILAYAH") @db.VarChar(50)
  namaWilayah     String?  @db.VarChar(255)
  latitude        Float?
  longitude       Float?
  radiusKm        Int      @default(5)
  config          Json?
  aiPromptStyle   String?  @db.VarChar(100)
  dorkingTargets  String[]
  isActive        Boolean  @default(true)
  leadsCount      Int      @default(0)
  hotLeadsCount   Int      @default(0)
  conversionRate  Float    @default(0.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  leads          Lead[]
  campaigns      Campaign[]
  activities     VRSentinelLog[]
  adProposals    AdProposal[]
  siteplanAssets SiteplanAsset[]

  @@index([namaProyek])
  @@index([tipeProyek])
  @@index([lokasi])
  @@index([isActive])
  @@index([createdAt])
}

// Lead Management - Core lead entity
model Lead {
  id             String   @id @default(cuid())
  business_name  String   @db.VarChar(255)
  contact        String   @db.VarChar(255)
  url            String?  @db.VarChar(500)
  keywords       String[]
  source         String   @default("manual") @db.VarChar(50)
  area           String?  @db.VarChar(255)
  projectId      String
  score          Int?
  status         String   @default("new") @db.VarChar(50)
  priority       String   @default("medium") @db.VarChar(50)
  platformSumber String?  @db.VarChar(50)
  jabatan        String?  @db.VarChar(255)
  nomorHp        String?  @db.VarChar(20)
  dateFound      DateTime @default(now())
  encryptedData  String?  @db.Text
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id])

  @@index([business_name])
  @@index([contact])
  @@index([area])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([score])
  @@index([nomorHp])
  @@index([createdAt])
}

// Campaign Management - Marketing campaigns
model Campaign {
  id               String    @id @default(cuid())
  name             String    @db.VarChar(255)
  description      String?   @db.Text
  mode             String    @db.VarChar(100)
  target_area      String?   @db.VarChar(255)
  keywords         String[]
  exclude_keywords String[]
  projectId        String
  status           String    @default("active") @db.VarChar(50)
  leads_count      Int       @default(0)
  hot_leads_count  Int       @default(0)
  conversion_rate  Float     @default(0.0)
  config           Json?
  start_date       DateTime  @default(now())
  end_date         DateTime?
  is_active        Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id])

  @@index([name])
  @@index([mode])
  @@index([projectId])
  @@index([status])
  @@index([is_active])
  @@index([createdAt])
}

// Activity Logging - System audit trail
model VRSentinelLog {
  id        String   @id @default(cuid())
  action    String   @db.VarChar(255)
  details   String?  @db.Text
  projectId String?
  userId    String?
  timestamp DateTime @default(now())
  metadata  Json?
  createdAt DateTime @default(now())

  // Relations
  project Project? @relation(fields: [projectId], references: [id])

  @@index([action])
  @@index([projectId])
  @@index([userId])
  @@index([timestamp])
  @@index([createdAt])
}

// System Configuration - Encrypted API keys and settings
model SystemConfig {
  id          String   @id @default(cuid())
  key_name    String   @unique @db.VarChar(100)
  key_value   String   @db.Text
  description String?  @db.Text
  category    String   @default("API_KEYS") @db.VarChar(50)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([key_name])
  @@index([category])
  @@index([is_active])
}

// Siteplan Asset Management - File uploads for VFX pipeline
model SiteplanAsset {
  id           String    @id @default(cuid())
  project_name String    @db.VarChar(255)
  file_url     String    @db.Text
  file_type    String    @db.VarChar(50)
  file_size    Int?
  file_hash    String?   @db.VarChar(64)
  status       String    @default("READY_FOR_VFX") @db.VarChar(50)
  metadata     Json?
  uploaded_by  String?   @db.VarChar(255)
  uploaded_at  DateTime  @default(now())
  processed_at DateTime?
  completed_at DateTime?
  project_id   String?

  // Relations
  project Project? @relation(fields: [project_id], references: [id])

  @@index([status])
  @@index([uploaded_at])
  @@index([project_name])
  @@index([file_type])
  @@index([project_id])
}

// Ad Proposal Management - Advertising proposals
model AdProposal {
  id             String   @id @default(cuid())
  projectId      String
  opsiStrategi   String   @db.Text
  targetAudience String   @db.Text
  copywriting    String   @db.Text
  estimasiBudget Int
  status         String   @default("PENDING") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  project Project @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

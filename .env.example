# 🔐 Environment Variables Template
# HUNTER_AGENT_AI_MARKETING_DIGITAL - AI Property Intelligence Bot
# ==========================================
# Copy this file to .env and fill in your actual API keys

# 🌐 Environment Configuration
# ==========================================

# Environment Mode
ENVIRONMENT=production
DEBUG=false

# 🚀 Production URLs
# ==========================================
FRONTEND_URL=https://lumina.devproflow.com
API_URL=https://lumina.devproflow.com/api
BACKEND_URL=https://lumina.devproflow.com/api
WEBHOOK_URL=https://lumina.devproflow.com/api/webhooks

# 🤖 AI & LLM Services
# ==========================================

# Google Gemini API (Required for AI Sentiment Analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Exa.ai Search API (Required for web search)
EXA_API_KEY=your_exa_api_key_here

# Firecrawl API (Required for web scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# 📱 Communication & Messaging
# ==========================================

# Telegram Bot Configuration (Required for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 🤖 DOOM SENTINEL Configuration
# ==========================================

# DOOM Admin Access (Required for security)
# Move admin credentials from hardcoded to environment
ADMIN_WA_NUMBERS=+6281234567890,+6281234567891
ADMIN_TELE_IDS=123456789,987654321

# Optional: Operator access (limited permissions)
OPERATOR_WA_NUMBERS=+6281234567892
OPERATOR_TELE_IDS=123456790

# Twilio WhatsApp Gateway (Required for WhatsApp integration)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# DOOM Alert System Configuration
DOOM_ALERT_COOLDOWN=300
DOOM_MONITORING_INTERVAL=60

# 🗄️ Database Configuration
# ==========================================

# Supabase (PostgreSQL) Production Database Configuration
# Get these values from your Supabase project settings > database
DATABASE_URL=""                    # Connection pooling URL from Supabase
DIRECT_URL=""                      # Direct connection URL for Prisma migrations

# Legacy PostgreSQL Configuration (for reference)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=lumina_production
DATABASE_USER=lumina_user
DATABASE_PASSWORD=your_secure_password_here

# Redis Configuration (Caching & Sessions)
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# 🌐 Web Application (Production)
# ==========================================

# Web Server Configuration
WEB_HOST=0.0.0.0
WEB_PORT=8000
WEB_DEBUG=false

# CORS Configuration (Production)
CORS_ORIGINS=["https://lumina.devproflow.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]
PUBLIC_URL=https://lumina.devproflow.com
ALLOWED_ORIGINS=https://lumina.devproflow.com
WS_URL=wss://lumina.devproflow.com

# 📊 Logging Configuration
# ==========================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log File Path
LOG_FILE=logs/bot_log.txt

# 🔐 Data Encryption & Security
# ==========================================

# Encryption key for sensitive data (phone numbers, PII)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_base64_encoded_encryption_key_here

# 🔓 License Management (DRM)
# ==========================================

# License key for commercial deployment
# Format: LUMINA-{CLIENT_ID}-{VERSION}-{HASH}
# Example: LUMINA-ABC123-1.0.0-a1b2c3d4e5f6
LUMINA_LICENSE_KEY=your_license_key_here

# 🤖 Machine-to-Machine Webhook Keys
# ==========================================

# Archidep M2M Webhook Secret Key
# Used to authenticate webhook requests from Archidep system
ARCHIDEP_SECRET_KEY=Lumina-Archidep-Secret-X99

# Additional M2M Secrets (for future integrations)
# EXTERNAL_SYSTEM_SECRET_KEY=your-secret-key-here
# PARTNER_API_SECRET_KEY=your-partner-secret-here

# Cost Control & Budget Management
# ==========================================

# AI API Budget Controls
AI_DAILY_BUDGET_USD=50.0
AI_MONTHLY_BUDGET_USD=1500.0

# WhatsApp API Budget Controls
WHATSAPP_DAILY_BUDGET_USD=20.0
WHATSAPP_MONTHLY_BUDGET_USD=600.0

# Telegram API Budget Controls
TELEGRAM_DAILY_BUDGET_USD=5.0
TELEGRAM_MONTHLY_BUDGET_USD=150.0

# Cost Alert Configuration
COST_ALERT_WEBHOOK=https://your-webhook-url.com/cost-alerts
ALERT_COOLDOWN_MINUTES=30

# ⚙️ Bot Configuration
# ==========================================

# Search Configuration
MAX_SEARCH_RESULTS=10
SEARCH_TIMEOUT=30

# Scraping Configuration
MAX_SCRAPING_RETRIES=3
SCRAPE_TIMEOUT=60

# Analysis Configuration
ANALYSIS_TEMPERATURE=0.3
ANALYSIS_MAX_TOKENS=1000

# 🚀 Server Configuration
# ==========================================

# Server Mode (development, production)
SERVER_MODE=development

# Cron Job Schedule (in cron format)
CRON_SCHEDULE=*/15 * * * *

# Process Management
MAX_CONCURRENT_PROCESSES=3
PROCESS_TIMEOUT=300

# 🔒 Security Configuration
# ==========================================

# Security Tokens
MASTER_TOKEN=your_master_token_here
WEBHOOK_SECRET=your_webhook_secret_here

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# � Google Sheets Integration (Required for Dashboard Bridge)
# ==========================================

# Google Sheets Service Account Credentials
# Path to your service account JSON file
GOOGLE_SHEETS_CREDENTIALS=config/google_sheets_credentials.json

# Google Sheets Spreadsheet Configuration
# Use either spreadsheet ID or URL (not both)
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
# GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/your_spreadsheet_id_here

# �📈 Analytics & Monitoring (Optional)
# ==========================================

# Google Analytics
GOOGLE_ANALYTICS_ID=your_google_analytics_id_here

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn_here

# ==========================================
# 📋 SETUP INSTRUCTIONS
# ==========================================

# 1. Copy this file to .env:
#    cp .env.example .env

# 2. Fill in your actual API keys:
#    - Get Gemini API key: https://makersuite.google.com/app/apikey
#    - Get Exa API key: https://exa.ai/api-keys
#    - Get Firecrawl API key: https://www.firecrawl.dev/
#    - Get Telegram Bot token: https://core.telegram.org/bots#creating-a-bot

# 3. Install dependencies:
#    pip install -r requirements.txt

# 4. Run the bot:
#    python main.py

# 5. For server deployment:
#    chmod +x bot_launcher.sh
#    ./bot_launcher.sh

# ==========================================
# ⚠️ IMPORTANT SECURITY NOTES
# ==========================================

# - Never commit .env file to version control
# - Keep API keys secure and private
# - Use different keys for development and production
# - Rotate API keys regularly
# - Monitor API usage and costs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id              String          @id @default(cuid())
  namaProyek      String          @db.VarChar(255)
  tipeProyek      String          @db.VarChar(50)
  lokasi          String          @db.VarChar(255)
  hargaStart      Float
  targetMarket    String          @db.VarChar(255)
  tipeInputLokasi String          @default("NAMA_WILAYAH") @db.VarChar(50)
  namaWilayah     String?         @db.VarChar(255)
  latitude        Float?
  longitude       Float?
  radiusKm        Int             @default(5)
  config          Json?
  aiPromptStyle   String?         @db.VarChar(100)
  dorkingTargets  String[]
  isActive        Boolean         @default(true)
  leadsCount      Int             @default(0)
  hotLeadsCount   Int             @default(0)
  conversionRate  Float           @default(0.0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  adProposals     AdProposal[]
  campaigns       Campaign[]
  leads           Lead[]
  siteplanAssets  SiteplanAsset[]
  activities      VRSentinelLog[]

  @@index([namaProyek])
  @@index([tipeProyek])
  @@index([lokasi])
  @@index([isActive])
  @@index([createdAt])
}

model Lead {
  id             String   @id @default(cuid())
  business_name  String   @db.VarChar(255)
  contact        String   @db.VarChar(255)
  url            String?  @db.VarChar(500)
  keywords       String[]
  source         String   @default("manual") @db.VarChar(50)
  area           String?  @db.VarChar(255)
  projectId      String
  score          Int?
  status         String   @default("new") @db.VarChar(50)
  priority       String   @default("medium") @db.VarChar(50)
  platformSumber String?  @db.VarChar(50)
  jabatan        String?  @db.VarChar(255)
  nomorHp        String?  @db.VarChar(20)
  dateFound      DateTime @default(now())
  encryptedData  String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id])

  @@index([business_name])
  @@index([contact])
  @@index([area])
  @@index([projectId])
  @@index([status])
  @@index([priority])
  @@index([score])
  @@index([nomorHp])
  @@index([createdAt])
}

model Campaign {
  id               String    @id @default(cuid())
  name             String    @db.VarChar(255)
  description      String?
  mode             String    @db.VarChar(100)
  target_area      String?   @db.VarChar(255)
  keywords         String[]
  exclude_keywords String[]
  projectId        String
  status           String    @default("active") @db.VarChar(50)
  leads_count      Int       @default(0)
  hot_leads_count  Int       @default(0)
  conversion_rate  Float     @default(0.0)
  config           Json?
  start_date       DateTime  @default(now())
  end_date         DateTime?
  is_active        Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  project          Project   @relation(fields: [projectId], references: [id])

  @@index([name])
  @@index([mode])
  @@index([projectId])
  @@index([status])
  @@index([is_active])
  @@index([createdAt])
}

model VRSentinelLog {
  id        String   @id @default(cuid())
  action    String   @db.VarChar(255)
  details   String?
  projectId String?
  userId    String?
  timestamp DateTime @default(now())
  metadata  Json?
  createdAt DateTime @default(now())
  project   Project? @relation(fields: [projectId], references: [id])

  @@index([action])
  @@index([projectId])
  @@index([userId])
  @@index([timestamp])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key_name    String   @unique @db.VarChar(100)
  key_value   String
  description String?
  category    String   @default("API_KEYS") @db.VarChar(50)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([key_name])
  @@index([category])
  @@index([is_active])
}

model SiteplanAsset {
  id           String    @id @default(cuid())
  project_name String    @db.VarChar(255)
  file_url     String
  file_type    String    @db.VarChar(50)
  file_size    Int?
  file_hash    String?   @db.VarChar(64)
  status       String    @default("READY_FOR_VFX") @db.VarChar(50)
  metadata     Json?
  uploaded_by  String?   @db.VarChar(255)
  uploaded_at  DateTime  @default(now())
  processed_at DateTime?
  completed_at DateTime?
  project_id   String?
  project      Project?  @relation(fields: [project_id], references: [id])

  @@index([status])
  @@index([uploaded_at])
  @@index([project_name])
  @@index([file_type])
  @@index([project_id])
}

model AdProposal {
  id             String   @id @default(cuid())
  projectId      String
  opsiStrategi   String
  targetAudience String
  copywriting    String
  estimasiBudget Int
  status         String   @default("PENDING") @db.VarChar(50)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  project        Project  @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([createdAt])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model aplikasi_kpr {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nasabah_id    String    @db.Uuid
  properti_id   String    @db.Uuid
  plafon_kredit Decimal   @db.Decimal(15, 2)
  tenor_tahun   Int
  bunga         Decimal?  @default(4.5) @db.Decimal(5, 2)
  status        String    @default("draft") @db.VarChar(20)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
  created_by    String?   @db.Uuid
  updated_by    String?   @db.Uuid

  @@index([created_at], map: "idx_aplikasi_created_at")
  @@index([nasabah_id], map: "idx_aplikasi_nasabah")
  @@index([status], map: "idx_aplikasi_status")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model audit_trail {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  action     String    @db.VarChar(50)
  table_name String    @db.VarChar(50)
  record_id  String?   @db.Uuid
  old_values Json?
  new_values Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  ip_address String?   @db.Inet
  user_agent String?

  @@index([created_at], map: "idx_audit_created_at")
  @@index([user_id], map: "idx_audit_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model dokumen {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  aplikasi_id  String    @db.Uuid
  nama_dokumen String    @db.VarChar(255)
  tipe_dokumen String    @db.VarChar(50)
  file_url     String?
  file_size    Int?
  mime_type    String?   @db.VarChar(100)
  status       String?   @default("pending") @db.VarChar(20)
  uploaded_at  DateTime? @default(now()) @db.Timestamptz(6)
  uploaded_by  String?   @db.Uuid

  @@index([aplikasi_id], map: "idx_dokumen_aplikasi")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model nasabah {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama               String    @db.VarChar(255)
  nik                String    @unique @db.VarChar(16)
  no_hp              String?   @db.VarChar(15)
  email              String?   @db.VarChar(255)
  alamat             String?
  pekerjaan          String?   @db.VarChar(100)
  pendapatan_bulanan Decimal?  @db.Decimal(12, 2)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
  updated_at         DateTime? @default(now()) @db.Timestamptz(6)

  @@index([email], map: "idx_nasabah_email")
  @@index([nik], map: "idx_nasabah_nik")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model notifications {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  title      String    @db.VarChar(255)
  message    String
  type       String    @db.VarChar(50)
  is_read    Boolean?  @default(false)
  data       Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  expires_at DateTime? @db.Timestamptz(6)

  @@index([is_read, user_id], map: "idx_notifications_unread")
  @@index([user_id], map: "idx_notifications_user")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model properti {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nama_proyek   String    @db.VarChar(255)
  tipe          String?   @db.VarChar(50)
  luas_tanah    Int?
  luas_bangunan Int?
  harga_jual    Decimal?  @db.Decimal(15, 2)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model users {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  nama          String    @db.VarChar(255)
  role          String    @default("user") @db.VarChar(50)
  permissions   String[]  @default(["read"])
  is_active     Boolean?  @default(true)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
}

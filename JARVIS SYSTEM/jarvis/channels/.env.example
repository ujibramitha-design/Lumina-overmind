# ============================================================================
# JARVIS COMMUNICATION CHANNELS - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# ============================================================================

# ----------------------------------------------------------------------------
# JARVIS SERVICE AUTHENTICATION
# ----------------------------------------------------------------------------
# Service token for JARVIS system account (root privileges)
# Generate a secure random token for production
JARVIS_SERVICE_TOKEN=jarvis_secret_token_v1_CHANGE_IN_PRODUCTION
JARVIS_TOKEN_ID=jarvis_service_token_v1

# ----------------------------------------------------------------------------
# GEMINI AI CONFIGURATION
# ----------------------------------------------------------------------------
# Google Gemini API key for JARVIS AI brain
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ----------------------------------------------------------------------------
# WHATSAPP CONFIGURATION
# ----------------------------------------------------------------------------
# Enable/disable WhatsApp integration
JARVIS_WHATSAPP_ENABLED=true

# Session storage path (LocalAuth will save session here)
JARVIS_WHATSAPP_SESSION_PATH=./jarvis/data/sessions/whatsapp

# WhatsApp business API (optional, for enterprise features)
# Leave empty if using whatsapp-web.js
JARVIS_WHATSAPP_BUSINESS_API_ID=
JARVIS_WHATSAPP_BUSINESS_API_TOKEN=

# ----------------------------------------------------------------------------
# TELEGRAM CONFIGURATION
# ----------------------------------------------------------------------------
# Enable/disable Telegram integration
JARVIS_TELEGRAM_ENABLED=true

# Telegram Bot Token (get from @BotFather)
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
JARVIS_TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Broadcast chat ID for sending messages to all users (optional)
# Get this by sending a message to your bot and checking the chat ID
JARVIS_TELEGRAM_BROADCAST_CHAT_ID=

# Admin user IDs (comma-separated) - these users have special privileges
JARVIS_TELEGRAM_ADMIN_IDS=

# ----------------------------------------------------------------------------
# CREATOR SECURITY LAYER (CRITICAL - DO NOT SHARE)
# ----------------------------------------------------------------------------
# Root Creator WhatsApp number (with country code, no + sign)
# Example: 6281234567890 for Indonesia
ROOT_CREATOR_WA_NUMBER=YOUR_WHATSAPP_NUMBER_HERE

# Root Creator Telegram ID (numeric ID, not username)
# Get this by sending a message to @userinfobot
ROOT_CREATOR_TG_ID=YOUR_TELEGRAM_ID_HERE

# Security verification token (optional, for additional verification)
ROOT_CREATOR_VERIFICATION_TOKEN=
# Get user IDs by sending /start to your bot and checking logs
JARVIS_TELEGRAM_ADMIN_IDS=

# ----------------------------------------------------------------------------
# WEBSOCKET CONFIGURATION
# ----------------------------------------------------------------------------
# WebSocket port for real-time communication
JARVIS_WEBSOCKET_PORT=3002

# WebSocket CORS allowed origins
JARVIS_WEBSOCKET_CORS_ORIGINS=*

# ----------------------------------------------------------------------------
# HEALTH CHECK CONFIGURATION
# ----------------------------------------------------------------------------
# Port for health check HTTP server
JARVIS_HEALTH_CHECK_PORT=3001

# Health check interval (seconds)
JARVIS_HEALTH_CHECK_INTERVAL=30

# ----------------------------------------------------------------------------
# PROACTIVE ENGINE CONFIGURATION
# ----------------------------------------------------------------------------
# Enable/disable proactive messaging
JARVIS_PROACTIVE_ENABLED=true

# Morning greeting time (24-hour format)
JARVIS_MORNING_GREETING_TIME=08:00

# Daily summary time (24-hour format)
JARVIS_DAILY_SUMMARY_TIME=18:00

# Timezone for scheduled tasks
JARVIS_TIMEZONE=Asia/Jakarta

# ----------------------------------------------------------------------------
# MEMORY MODULE CONFIGURATION
# ----------------------------------------------------------------------------
# Memory storage type: sqlite, redis, or json
JARVIS_MEMORY_STORAGE_TYPE=sqlite

# SQLite database path
JARVIS_MEMORY_DB_PATH=./jarvis/data/jarvis_memory.db

# Redis connection (if using redis storage)
JARVIS_MEMORY_REDIS_URL=redis://localhost:6379/1

# Memory retention days (how long to keep conversation history)
JARVIS_MEMORY_RETENTION_DAYS=30

# ----------------------------------------------------------------------------
# CODEBASE AWARENESS CONFIGURATION
# ----------------------------------------------------------------------------
# Enable/disable codebase awareness
JARVIS_CODE_AWARENESS_ENABLED=true

# Code index path
JARVIS_CODE_INDEX_PATH=./jarvis/data/code_index

# Embedding model (sentence-transformers)
JARVIS_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector database type: chroma or faiss
JARVIS_VECTOR_DB_TYPE=chroma

# ChromaDB persistence path
JARVIS_CHROMA_PERSIST_PATH=./jarvis/data/code_index/chroma_db

# Auto-reindex on file changes
JARVIS_CODE_AUTO_REINDEX=true

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------
# Log level: debug, info, warn, error
JARVIS_LOG_LEVEL=info

# Log file path
JARVIS_LOG_FILE=./logs/jarvis_channels.log

# Enable console logging
JARVIS_LOG_CONSOLE=true

# ----------------------------------------------------------------------------
# RATE LIMITING CONFIGURATION
# ----------------------------------------------------------------------------
# Messages per minute per user
JARVIS_RATE_LIMIT_PER_MINUTE=30

# Messages per hour per user
JARVIS_RATE_LIMIT_PER_HOUR=100

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------------------
# Enable IP whitelist (optional)
JARVIS_IP_WHITELIST_ENABLED=false

# Allowed IP addresses (comma-separated)
JARVIS_ALLOWED_IPS=127.0.0.1,::1

# Enable request signing
JARVIS_REQUEST_SIGNING_ENABLED=false

# ----------------------------------------------------------------------------
# DEVELOPMENT/DEBUGGING
# ----------------------------------------------------------------------------
# Enable debug mode
JARVIS_DEBUG=false

# Enable test mode (doesn't send actual messages)
JARVIS_TEST_MODE=false

# Mock responses for testing
JARVIS_MOCK_RESPONSES=false
